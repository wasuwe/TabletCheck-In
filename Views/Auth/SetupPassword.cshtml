@{
    Layout = "~/Views/Shared/_Layout.cshtml";
    ViewBag.Title = "Setup New Password";
}

@section Styles {
    <style>
        .global-navbar {
            display: none !important;
        }

        .setup-container {
            min-height: 100vh;
            display: flex;
            align-items: center;
            justify-content: center;
        }

        .setup-box {
            max-width: 400px;
            width: 100%;
            padding: 40px 30px;
        }

        .form-control-login {
            background: rgba(0,0,0,0.4) !important;
            color: #fff !important;
            border: 1px solid rgba(255,255,255,0.1);
            border-radius: 50px;
            padding-left: 20px;
            height: 50px;
            text-align: center;
            font-size: 1.1rem;
            letter-spacing: 2px;
        }

            .form-control-login:focus {
                border-color: #00ff88;
                box-shadow: 0 0 15px rgba(0,255,136,0.3);
                outline: none;
            }

        .btn-neon {
            background: linear-gradient(90deg, #00b09b, #96c93d);
            border: none;
            color: white;
            font-weight: 800;
            border-radius: 50px;
            padding: 14px 20px;
            box-shadow: 0 4px 15px rgba(0, 176, 155, 0.4);
            width: 100%;
            letter-spacing: 1px;
        }
    </style>
}

<div class="setup-container">
    <div class="glass-panel setup-box text-center">
        <i class="fa fa-unlock-alt" style="font-size: 3rem; color: #00ff88; margin-bottom: 15px;"></i>
        <h3 class="font-weight-bold mb-1">Set Password</h3>
        <p class="text-warning small mb-4">Hello <b>@ViewBag.Username</b>, please set your new password.</p>

        <form id="frmSetup">
            @Html.AntiForgeryToken()
            <input type="hidden" id="token" value="@ViewBag.Token" />

            <div class="form-group mb-3">
                <input type="password" id="txtPass1" class="form-control-login" placeholder="New Password" required autofocus>
            </div>
            <div class="form-group mb-4">
                <input type="password" id="txtPass2" class="form-control-login" placeholder="Confirm Password" required>
            </div>

            <button type="submit" class="btn btn-neon" id="btnSubmit">SAVE PASSWORD</button>
            <div id="lblMsg" class="text-danger small mt-3 font-weight-bold" style="height: 20px;"></div>
        </form>
    </div>
</div>

@section Scripts {
    <script>
        $(document).ready(function() {
            $('#frmSetup').on('submit', function(e) {
                e.preventDefault();

                let p1 = $('#txtPass1').val();
                let p2 = $('#txtPass2').val();
                let tk = $('#token').val();
                let btn = $('#btnSubmit');

                if(p1 !== p2) {
                    $('#lblMsg').text("Passwords do not match!");
                    return;
                }

                if(p1.length < 4) {
                    $('#lblMsg').text("Password must be at least 4 characters.");
                    return;
                }

                btn.html('<i class="fa fa-spinner fa-spin"></i> SAVING...').prop('disabled', true);
                $('#lblMsg').text('');

                let fd = new FormData();
                fd.append('token', tk);
                fd.append('new_password', p1);

                fetch('@Url.Action("DoSetupPassword", "Auth")', { method: 'POST', body: fd })
                .then(r => r.json()).then(d => {
                    if(d.status === 'success') {
                        Swal.fire({ icon: 'success', title: 'Success', text: 'Password saved!', timer: 1500, showConfirmButton: false, background: '#1a2530', color: '#fff' })
                        .then(() => { window.location.href = d.redirectUrl; });
                    } else {
                        $('#lblMsg').text(d.message);
                        btn.html('SAVE PASSWORD').prop('disabled', false);
                    }
                });
            });
        });
    </script>
}