@using TabletCheckIn.Utility
@{
    Layout = "~/Views/Shared/_Layout.cshtml";
    ViewBag.Title = "Manage Devices";
}

@section Styles {
    <style>
        /* UI ELEMENTS */
        .btn-outline-light {
            border-radius: 50px;
            padding: 8px 20px;
            border: 1px solid rgba(255,255,255,0.3);
        }

        .form-control {
            background: rgba(255, 255, 255, 0.05);
            border: 1px solid rgba(255, 255, 255, 0.2);
            color: #fff !important;
            border-radius: 8px;
            height: 42px;
            transition: all 0.2s ease;
        }

            .form-control:focus {
                background: rgba(255, 255, 255, 0.1);
                border-color: #00ff88;
                box-shadow: none;
                outline: none;
            }

            .form-control::placeholder {
                color: rgba(255,255,255,0.3);
            }

        select option {
            background-color: #1a262b;
            color: white;
        }

        /* TABLE */
        .table-container {
            border-radius: 16px;
            overflow: hidden;
            background: rgba(30, 40, 50, 0.4);
            border: 1px solid rgba(255,255,255,0.05);
        }

        .table-responsive {
            overflow-x: auto;
        }

        .table-glass {
            width: 100%;
            border-collapse: separate;
            border-spacing: 0 6px;
            min-width: 900px;
        }

            .table-glass th {
                padding: 15px;
                color: #00ff88;
                font-weight: 500;
                text-transform: uppercase;
                font-size: 0.85rem;
                border: none;
                text-align: center;
            }

                .table-glass th.text-left {
                    text-align: left;
                }

            .table-glass tbody tr {
                background: rgba(40, 50, 60, 0.6);
            }

            .table-glass td {
                padding: 12px 15px;
                border-top: 1px solid rgba(0,0,0,0.2);
                border-bottom: 1px solid rgba(0,0,0,0.2);
                vertical-align: middle;
            }

                .table-glass td:first-child {
                    border-radius: 10px 0 0 10px;
                    border-left: 1px solid rgba(0,0,0,0.2);
                }

                .table-glass td:last-child {
                    border-radius: 0 10px 10px 0;
                    border-right: 1px solid rgba(0,0,0,0.2);
                }

        /* SIDEBAR */
        .sidebar-backdrop {
            position: fixed;
            top: 0;
            left: 0;
            width: 100vw;
            height: 100vh;
            background: rgba(0, 0, 0, 0.7);
            z-index: 1040;
            opacity: 0;
            pointer-events: none;
            transition: opacity 0.3s ease;
        }

            .sidebar-backdrop.active {
                opacity: 1;
                pointer-events: auto;
            }

        .editor-sidebar {
            position: fixed;
            top: 0;
            right: -500px;
            width: 450px;
            max-width: 100vw;
            height: 100vh;
            background: #101920;
            z-index: 1050;
            transition: right 0.4s;
            display: flex;
            flex-direction: column;
            border-left: 1px solid #333;
        }

            .editor-sidebar.active {
                right: 0;
            }

        .editor-header {
            padding: 20px 25px;
            background: rgba(0,0,0,0.2);
        }

        .editor-body {
            flex: 1;
            overflow-y: auto;
            padding: 0;
        }

        /* TABS */
        .nav-tabs {
            border-bottom: 1px solid rgba(255,255,255,0.1);
        }

            .nav-tabs .nav-link {
                color: #888;
                border: none;
                font-weight: 600;
                padding: 15px 20px;
            }

                .nav-tabs .nav-link:hover {
                    color: #fff;
                }

                .nav-tabs .nav-link.active {
                    color: #00ff88;
                    background: transparent;
                    border-bottom: 2px solid #00ff88;
                }

        /* CHECKBOX */
        .custom-control-label::before {
            background-color: rgba(255,255,255,0.1);
            border: 1px solid rgba(255,255,255,0.3);
        }

        .custom-checkbox .custom-control-input:checked ~ .custom-control-label::before {
            background-color: #00ff88;
            border-color: #00ff88;
        }

        /* LOGS */
        .timeline-item {
            position: relative;
            padding-left: 20px;
            border-left: 2px solid rgba(255,255,255,0.1);
            margin-bottom: 15px;
            padding-bottom: 5px;
        }

            .timeline-item::before {
                content: '';
                position: absolute;
                left: -6px;
                top: 5px;
                width: 10px;
                height: 10px;
                border-radius: 50%;
                background: #00ff88;
                box-shadow: 0 0 5px #00ff88;
            }

        .timeline-date {
            font-size: 0.75rem;
            color: #888;
            margin-bottom: 2px;
        }

        .timeline-action {
            font-weight: bold;
            color: #fff;
            font-size: 0.9rem;
        }

        .timeline-detail {
            color: #ccc;
            font-size: 0.85rem;
            background: rgba(255,255,255,0.05);
            padding: 8px;
            border-radius: 6px;
            margin-top: 5px;
        }

        .log-change-container {
            background: rgba(0, 0, 0, 0.2);
            border-radius: 8px;
            padding: 8px 12px;
            margin-top: 5px;
        }

        .log-change-item {
            display: flex;
            align-items: center;
            padding: 4px 0;
            border-bottom: 1px solid rgba(255, 255, 255, 0.05);
            font-size: 0.85rem;
        }

            .log-change-item:last-child {
                border-bottom: none;
            }

        .change-label {
            width: 120px;
            color: #00b09b;
            font-weight: 600;
            flex-shrink: 0;
        }

        .change-old {
            color: #ff6b6b;
            text-decoration: line-through;
            opacity: 0.7;
            margin-right: 8px;
        }

        .change-arrow {
            color: #6c757d;
            font-size: 0.8rem;
            margin: 0 8px;
        }

        .change-new {
            color: #00ff88;
            font-weight: bold;
        }

        /* 🌟 NEW: SKELETON LOADING CSS 🌟 */
        .skeleton-box {
            background: linear-gradient(90deg, rgba(255,255,255,0.03) 25%, rgba(255,255,255,0.08) 50%, rgba(255,255,255,0.03) 75%);
            background-size: 200% 100%;
            animation: skeleton-loading 1.5s infinite ease-in-out;
            border-radius: 8px;
        }

        @@keyframes skeleton-loading {
            0% { background-position: 200% 0; }
            100% { background-position: -200% 0; }
        }

        .skeleton-text {
            height: 15px;
            margin-bottom: 8px;
            border-radius: 4px;
        }

        .skeleton-badge {
            height: 22px;
            width: 25px;
            display: inline-block;
            border-radius: 4px;
            margin: 0 2px;
        }

        .skeleton-btn {
            height: 32px;
            width: 32px;
            display: inline-block;
            border-radius: 50%;
            margin: 0 2px;
        }

        @@media (max-width: 768px) {
            .editor-sidebar {
                width: 100%;
            }
        }

        /* 🌟 SUMMARY RECORD 🌟 */
        .summary-record {
            display: flex;
            background: rgba(0, 0, 0, 0.2);
            border: 1px solid rgba(255, 255, 255, 0.1);
            border-radius: 8px;
            overflow-x: auto; /* เผื่อมีแผนกเยอะ จะเลื่อนซ้ายขวาได้ */
        }

        .summary-col {
            flex: 1;
            min-width: 110px;
            text-align: center;
            border-right: 1px solid rgba(255, 255, 255, 0.05);
        }

            .summary-col:last-child {
                border-right: none;
            }

        .summary-head {
            background: rgba(255, 255, 255, 0.05);
            font-size: 0.75rem;
            color: rgba(255, 255, 255, 0.6);
            padding: 8px 10px;
            text-transform: uppercase;
            letter-spacing: 0.5px;
        }

        .summary-body {
            padding: 12px 10px;
            font-size: 1.2rem;
            font-weight: bold;
            color: #17a2b8; /* สีฟ้านีออน text-info */
        }

        /* ไฮไลท์ช่อง Total */
        .summary-col.total-col .summary-head {
            color: #00ff88;
            background: rgba(0, 255, 136, 0.1);
            font-weight: bold;
        }

        .summary-col.total-col .summary-body {
            color: #ffffff;
            background: rgba(0, 255, 136, 0.05);
            font-size: 1.3rem;
        }

        /* 🌟 FILTER BADGES 🌟 */
        .filter-badge {
            cursor: pointer;
            transition: all 0.2s ease;
            user-select: none;
        }

            .filter-badge:hover {
                transform: translateY(-2px);
                box-shadow: 0 4px 8px rgba(0,0,0,0.3);
                border-color: rgba(255,255,255,0.5) !important;
            }

            .filter-badge.active {
                background: rgba(0, 255, 136, 0.2) !important;
                border-color: #00ff88 !important;
                color: #fff !important;
            }

                .filter-badge.active .text-info {
                    color: #00ff88 !important;
                }
    </style>
}

<div class="container-fluid py-2">

    <div class="row align-items-center mb-4">
        <div class="col-12 col-lg-5 mb-3 mb-lg-0">
            <h2 class="mb-0 font-weight-bold"><i class="fa fa-tasks text-success mr-2"></i>Manage Devices</h2>
        </div>
        <div class="col-12 col-lg-7 d-flex flex-column flex-md-row justify-content-lg-end align-items-md-center">
            <button class="btn btn-neon rounded-pill shadow mb-2 mb-md-0 mr-md-3" onclick="openEditor('add')">
                <i class="fa fa-plus"></i> Add New
            </button>
            <div class="position-relative" style="width: 100%; max-width: 350px;">
                <input type="text" id="searchDevice" class="form-control rounded-pill pl-5" style="height: 40px;" placeholder="Search anything (Asset, IP, Owner...)">
                <i class="fa fa-search position-absolute text-muted" style="left: 18px; top: 13px;"></i>
            </div>
        </div>

        <div class="col-12 ">
            <div id="assetSummary" class="mt-3 w-100"></div>
        </div>
    </div>

    <div class="table-container">
        <div class="table-responsive">
            <table class="table-glass">
                <thead>
                    <tr>
                        <th width="15%" class="text-left pl-4">IT Asset / Host</th>
                        <th width="25%">Dept / Owner / By</th>
                        <th width="15%" class="text-center">Registered</th>
                        <th width="10%" class="text-center">Target</th>
                        <th width="10%" class="text-center">Status</th>
                        <th width="15%" class="text-center">Action</th>
                    </tr>
                </thead>
                <tbody id="tableBody"></tbody>
            </table>
        </div>
    </div>
</div>

<div id="sidebarBackdrop" class="sidebar-backdrop" onclick="checkDirtyAndClose()"></div>
<div id="editorSidebar" class="editor-sidebar">

    <div class="editor-header pb-0 d-block">
        <div class="d-flex justify-content-between align-items-center mb-2">
            <h5 class="mb-0 font-weight-bold text-white" id="sidebarTitle">Edit Device</h5>
            <button type="button" class="btn btn-sm btn-outline-light rounded-circle border-0 " onclick="checkDirtyAndClose()"><i class="fa fa-times"></i></button>
        </div>
        <ul class="nav nav-tabs" id="myTab" role="tablist">
            <li class="nav-item"><a class="nav-link active" id="info-tab" data-toggle="tab" href="#info" role="tab"><i class="fa fa-pencil mr-1"></i>Info</a></li>
            <li class="nav-item"><a class="nav-link" id="log-tab" data-toggle="tab" href="#log" role="tab"><i class="fa fa-history mr-1"></i>Activity Log</a></li>
        </ul>
    </div>

    <div class="editor-body">
        <div class="tab-content h-100">
            <div class="tab-pane fade show active p-4" id="info" role="tabpanel">

                <form id="regForm">
                    @Html.AntiForgeryToken()
                    <input type="hidden" name="data_id" id="data_id" />

                    <div class="form-group mb-3"><label class="text-success font-weight-bold small">ASSET NO *</label><input type="text" name="asset_no" id="asset_no" class="form-control" required /></div>
                    <div class="form-group mb-3">
                        <label class="text-success font-weight-bold small">STATUS</label>
                        <select name="status" id="status" class="form-control"><option value="Delivered">Active (Delivered)</option><option value="Stock">Stock</option></select>
                    </div>

                    <div class="glass-panel p-3 mb-3">
                        <label class="text-warning font-weight-bold small mb-2 d-block"><i class="fa fa-clock-o"></i> TARGET</label>
                        <div class="custom-control custom-checkbox mb-2">
                            <input type="checkbox" class="custom-control-input" id="check_morn" name="check_morn"><label class="custom-control-label text-white-50" for="check_morn">Morning</label>
                        </div>
                        <div class="custom-control custom-checkbox">
                            <input type="checkbox" class="custom-control-input" id="check_night" name="check_night"><label class="custom-control-label text-white-50" for="check_night">Night</label>
                        </div>
                    </div>

                    <div class="row">
                        <div class="col-6 mb-3"><label class="text-muted small">HOST</label><input type="text" name="host_name" id="host_name" class="form-control" /></div>
                        <div class="col-6 mb-3"><label class="text-muted small">OWNER</label><input type="text" name="owner" id="owner" class="form-control" /></div>
                    </div>
                    <div class="form-group mb-3">
                        <label class="text-muted small">DEPT</label>
                        <select name="dept" id="dept" class="form-control"><option value="">--</option></select>
                    </div>
                    <div class="form-group mb-3">
                        <label class="text-muted small">DETAIL</label>
                        <textarea name="detail" id="detail" class="form-control" rows="2" placeholder="Additional details..."></textarea>
                    </div>

                    <div class="text-right mt-4">
                        <button type="button" class="btn btn-outline-light rounded-pill mr-2" onclick="checkDirtyAndClose()">Cancel</button>
                        <button type="submit" class="btn btn-neon rounded-pill px-4" id="btnSave">Save Changes</button>
                    </div>
                </form>
            </div>

            <div class="tab-pane fade p-4" id="log" role="tabpanel">
                <div id="logContainer"></div>
            </div>
        </div>
    </div>
</div>

@section Scripts {
<script>
        let isFormDirty = false;
        let originalData = null;
        let selectedFilterDepts = []; // 🌟 เก็บรายชื่อแผนกที่คลิกเลือก

        $(document).ready(function () {
            loadTable();
            loadDepts();

            $('#regForm input, #regForm select').on('change input', function () { isFormDirty = true; });

            $('#regForm').on('submit', function (e) {
                e.preventDefault();
                let fd = new FormData(this);
                fd.set('check_morn', $('#check_morn').is(':checked'));
                fd.set('check_night', $('#check_night').is(':checked'));

                let changeLog = getChangeDetails();
                fd.append('change_details', changeLog);

                let btn = $('#btnSave'); let txt = btn.html();
                btn.html('<i class="fa fa-spinner fa-spin"></i> Saving...').prop('disabled', true);

                fetch('@Url.Action("Save", "Device")', { method: 'POST', body: fd })
                    .then(r => r.json())
                    .then(d => {
                        btn.html(txt).prop('disabled', false);
                        if (d.status === 'success') {
                            Swal.fire({ icon: 'success', title: 'Saved', timer: 1000, showConfirmButton: false, background: '#1a2530', color: '#fff' });
                            isFormDirty = false;
                            closeEditor();
                            loadTable();
                        } else {
                            if(d.message === 'Session expired.') window.location.href = '@Url.Action("Index", "Auth")';
                            else Swal.fire({title: 'Error', text: d.message, icon: 'error', background: '#1a2530', color: '#fff'});
                        }
                    });
            });

            $('a[data-toggle="tab"]').on('shown.bs.tab', function (e) {
                if (e.target.id === 'log-tab') {
                    let deviceId = $('#data_id').val();
                    if (deviceId) loadLogs(deviceId);
                }
            });

            // 🌟 ให้ Search ทำงานร่วมกับ Filter แผนก 🌟
            $("#searchDevice").on("keyup", function() {
                applyDeviceFilters();
            });
        });

        // 🌟 NEW: ฟังก์ชันโชว์ Skeleton Loader (ใช้ของเดิมของคุณ)
        function showSkeletonLoader() {
            let html = '';
            for(let i=0; i<5; i++) {
                html += `<tr><td class="pl-4"><div class="skeleton-box skeleton-text w-75" style="height: 16px;"></div><div class="skeleton-box skeleton-text w-50" style="height: 12px; margin-bottom: 0;"></div></td><td><div class="skeleton-box skeleton-text w-100" style="height: 16px;"></div></td><td><div class="skeleton-box skeleton-text w-50" style="height: 14px;"></div><div class="skeleton-box skeleton-text w-75" style="height: 12px;"></div><div class="skeleton-box skeleton-text w-50" style="height: 12px; margin-bottom: 0;"></div></td><td class="text-center"><div class="skeleton-box skeleton-text w-75 mx-auto" style="height: 14px;"></div></td><td class="text-center"><div class="skeleton-box skeleton-badge"></div><div class="skeleton-box skeleton-badge"></div></td><td class="text-center"><div class="skeleton-box skeleton-badge mx-auto" style="width: 50px;"></div></td><td class="text-center"><div class="skeleton-box skeleton-btn"></div><div class="skeleton-box skeleton-btn"></div></td></tr>`;
            }
            $('#tableBody').html(html);
        }

        // ================== API CALLS & TABLE LOAD ==================
        function loadTable() {
            showSkeletonLoader();

            fetch('@Url.Action("GetList", "Device")')
                .then(r => r.json())
                .then(d => {
                    if(d.status === 'error') {
                        window.location.href = '@Url.Action("Index", "Auth")';
                        return;
                    }

                    // 🌟 คำนวณสรุปยอดรวมและสร้างปุ่ม Filter 🌟
                    let totalAssets = d.length;
                    let deptCount = {};

                    d.forEach(r => {
                        let dept = (r.dept_name && r.dept_name.trim() !== '') ? r.dept_name : 'No Dept';
                        deptCount[dept] = (deptCount[dept] || 0) + 1;
                    });

                    $('#assetSummary').addClass('d-flex flex-wrap align-items-center mb-3');

                    // 🌟 ปุ่ม Total ใช้สำหรับเคลียร์ Filter ทั้งหมด
                    let summaryHtml = `<span class="badge badge-success px-3 py-2 mr-2 mb-1 shadow-sm filter-badge" id="btnFilterTotal" onclick="clearDeptFilters()" style="font-size: 0.85rem;">
                                            Total: ${totalAssets}
                                       </span>`;

                    for (const [dept, count] of Object.entries(deptCount)) {
                        summaryHtml += `<span class="badge px-2 py-2 mr-2 mb-1 filter-badge filter-dept-btn" data-dept="${dept}" style="font-size: 0.8rem; background: rgba(255,255,255,0.08); border: 1px solid rgba(255,255,255,0.2); color: #ccc;">
                                            ${dept}: <b class="text-info ml-1" style="font-size: 0.9rem;">${count}</b>
                                        </span>`;
                    }
                    $('#assetSummary').html(summaryHtml);
                    // ---------------------------------------------

                    let h = '';
                    d.forEach(r => {
                        let displayDept = (r.dept_name && r.dept_name.trim() !== '') ? r.dept_name : 'No Dept';
                        // 🌟 แปะ data-dept เพื่อให้กรองง่ายขึ้น
                        h += `<tr data-dept="${displayDept}">
                            <td class="pl-4"><b>${r.asset_no}</b><div class="small text-white-50">${r.host_name}</div></td>
                            <td>
                                <span class="font-weight-bold text-info">${r.dept_name}</span><br>
                                <small class="text-white-50">Owner: ${r.owner_name}</small><br>
                                <small class="text-warning" title="Updated by"><i class="fa fa-user-circle-o"></i> ${r.last_updated_by}</small>
                            </td>
                            <td class="text-center text-white-50 small"><i class="fa fa-calendar-o mr-1"></i> ${r.registered_at}</td>
                            <td class="text-center">
                                ${r.check_morn ? '<span class="badge badge-warning mr-1">M</span>' : '<span class="badge badge-secondary mr-1" style="opacity:0.3">M</span>'}
                                ${r.check_night ? '<span class="badge badge-info">N</span>' : '<span class="badge badge-secondary" style="opacity:0.3">N</span>'}
                            </td>
                            <td class="text-center">${r.status === 'Delivered' ? '<span class="badge badge-success">Active</span>' : '<span class="badge badge-secondary">Stock</span>'}</td>
                            <td class="text-center">
                                <button class="btn btn-sm btn-outline-warning rounded-circle shadow-none" onclick='openEditor("edit", ${JSON.stringify(r).replace(/'/g, "&#39;")})'><i class="fa fa-pencil"></i></button>
                                <button class="btn btn-sm btn-outline-danger rounded-circle shadow-none" onclick="deleteItem('${r.id}')"><i class="fa fa-trash"></i></button>
                            </td>
                        </tr>`;
                    });
                    $('#tableBody').html(h);

                    // 🌟 ผูก Event การคลิก Filter และรัน Filter ตรวจสอบสถานะเดิม
                    bindDeptFilterEvents();
                    applyDeviceFilters();
                });
        }

        // ================== FILTER LOGIC ==================
        function bindDeptFilterEvents() {
            $('.filter-dept-btn').off('click').on('click', function() {
                let dept = $(this).data('dept');

                if (selectedFilterDepts.includes(dept)) {
                    selectedFilterDepts = selectedFilterDepts.filter(d => d !== dept); // ถอดออก
                    $(this).removeClass('active');
                } else {
                    selectedFilterDepts.push(dept); // เพิ่มเข้า
                    $(this).addClass('active');
                }
                applyDeviceFilters();
            });
        }

        function clearDeptFilters() {
            selectedFilterDepts = [];
            $('.filter-dept-btn').removeClass('active');
            applyDeviceFilters();
        }

        function applyDeviceFilters() {
            let searchText = $("#searchDevice").val().toLowerCase();

            $("#tableBody tr").each(function() {
                let rowText = $(this).text().toLowerCase();
                let rowDept = $(this).data('dept');

                let matchSearch = rowText.indexOf(searchText) > -1;
                let matchDept = selectedFilterDepts.length === 0 || selectedFilterDepts.includes(rowDept);

                if (matchSearch && matchDept) {
                    $(this).show();
                } else {
                    $(this).hide();
                }
            });

            // หรี่แสงปุ่ม Total เวลาที่แผนกถูกเลือก
            if (selectedFilterDepts.length > 0) {
                $('#btnFilterTotal').removeClass('badge-success').addClass('badge-secondary').css('opacity', '0.5');
            } else {
                $('#btnFilterTotal').removeClass('badge-secondary').addClass('badge-success').css('opacity', '1');
            }
        }

        function loadDepts() {
            fetch('@Url.Action("GetDepartments", "Device")').then(r => r.json()).then(d => {
                let h = '<option value="">-- Select Department --</option>';

                let isAdmin = @(AuthHelper.HasRole("Admin").ToString().ToLower());

                if (d && d.length > 0) {
                    d.forEach(x => h += `<option value="${x}">${x}</option>`);
                }

                $('#dept').html(h);

                if (!isAdmin && d && d.length === 1) {
                    $('#dept').val(d[0]);
                    $('#dept option[value=""]').remove();
                }
            });
        }

        function deleteItem(id) {
            Swal.fire({
                title: 'Delete this device?', icon: 'warning', showCancelButton: true, confirmButtonColor: '#d33', background: '#1a2530', color: '#fff'
            }).then((result) => {
                if (result.isConfirmed) {
                    let fd = new FormData();
                    fd.append('del_id', id);
                    let token = $('input[name="__RequestVerificationToken"]').val();
                    fd.append('__RequestVerificationToken', token);

                    fetch('@Url.Action("Delete", "Device")', { method: 'POST', body: fd })
                    .then(r => r.json())
                    .then(d => {
                        if(d.status === 'success') loadTable();
                        else Swal.fire({title: 'Error', text: d.message, icon: 'error', background: '#1a2530', color: '#fff'});
                    });
                }
            });
        }

        // ================== EDITOR LOGIC ==================
        let curLogDeviceId = ''; let curLogOffset = 0;
        function loadLogs(deviceId, append = false) {
            if (!append) {
                curLogDeviceId = deviceId; curLogOffset = 0;
                $('#logContainer').html('<div class="text-center py-5"><i class="fa fa-spinner fa-spin text-success"></i> Loading...</div>');
            } else {
                $('#btnLoadMoreLogs').html('<i class="fa fa-spinner fa-spin"></i>...').prop('disabled', true);
            }

            fetch(`@Url.Action("GetLogs", "Device")?id=${curLogDeviceId}&offset=${curLogOffset}`)
                .then(r => r.json())
                .then(data => {
                    let html = '';
                    if (data.length === 0 && !append) {
                        $('#logContainer').html('<div class="text-center text-muted mt-5">No activity recorded.</div>');
                        return;
                    }

                    data.forEach(log => {
                        let formattedDetails = formatDetails(log.details);
                        html += `<div class="timeline-item type-${log.action}">
                                    <div class="timeline-date"><i class="fa fa-calendar-o mr-1"></i> ${log.date}</div>
                                    <div class="timeline-action">${log.action}</div>
                                    <div class="timeline-detail">${formattedDetails}</div>
                                </div>`;
                    });

                    if (!append) {
                        $('#logContainer').html(`<div id="logListWrapper" class="mt-2">${html}</div><div id="loadMoreLogWrapper" class="text-center pb-3 pt-2"></div>`);
                    } else {
                        $('#logListWrapper').append(html);
                    }

                    if (data.length === 20) {
                        $('#loadMoreLogWrapper').html(`<button id="btnLoadMoreLogs" class="btn btn-sm btn-outline-success rounded-pill px-4" onclick="loadMoreLogs()">Load More</button>`);
                    } else {
                        $('#loadMoreLogWrapper').empty();
                    }
                });
        }
        function loadMoreLogs() { curLogOffset += 20; loadLogs(curLogDeviceId, true); }

        function getChangeDetails() {
            if (!originalData) return "New Registration";
            let changes = [];
            const compare = (id, key, label) => { let newVal = $(id).val() || ""; let oldVal = originalData[key] || ""; if (newVal != oldVal) changes.push(`${label}: '${oldVal}' -> '${newVal}'`); };
            const compareBool = (id, key, label) => { let newVal = $(id).is(':checked'); let oldVal = originalData[key] === true; if (newVal !== oldVal) changes.push(`${label}: ${oldVal ? 'Yes' : 'No'} -> ${newVal ? 'Yes' : 'No'}`); };
            compare('#asset_no', 'asset_no', 'Asset No'); compare('#status', 'status', 'Status'); compare('#host_name', 'host_name', 'Host Name'); compare('#owner', 'owner_name', 'Owner'); compare('#dept', 'dept_name', 'Department'); compare('#detail', 'detail', 'Detail'); compareBool('#check_morn', 'check_morn', 'Target Morning'); compareBool('#check_night', 'check_night', 'Target Night');
            return changes.length > 0 ? changes.join(', ') : "No changes detected";
        }

        function formatDetails(txt) {
            if (!txt) return '-';
            if (txt.includes('->')) {
                let html = '<div class="log-change-container">';
                txt.split(', ').forEach(p => {
                    let match = p.match(/(.*?):\s*(.*?)\s*->\s*(.*)/);
                    if (match) {
                        let label = match[1].trim(), oldV = match[2].trim().replace(/^'|'$/g, ''), newV = match[3].trim().replace(/^'|'$/g, '');
                        html += `<div class="log-change-item"><div class="change-label">${label}</div><div class=""><span class="change-old">${oldV || '<em class="small">Empty</em>'}</span><i class="fa fa-long-arrow-right change-arrow"></i><span class="change-new">${newV}</span></div></div>`;
                    } else { html += `<div class="log-change-item text-white-50">${p}</div>`; }
                });
                return html + '</div>';
            }
            return `<div class="text-white-50 p-1">${txt}</div>`;
        }

        function openEditor(mode, data = null) {
            isFormDirty = false; $('#regForm')[0].reset(); $('#data_id').val(''); $('#detail').val('');
            $('#info-tab').trigger('click');

            let isAdmin = @(AuthHelper.HasRole("Admin").ToString().ToLower());

            if (mode === 'add') {
                originalData = null; $('#sidebarTitle').text('New Device');
                $('#check_morn').prop('checked', true); $('#check_night').prop('checked', true);
                $('#log-tab').addClass('disabled'); $('#logContainer').html('<div class="text-center text-muted mt-5">Save the device first to see logs.</div>');

                if (!isAdmin && $('#dept option').length === 1) {
                    $('#dept').prop('selectedIndex', 0);
                } else {
                    $('#dept').val('');
                }
            } else {
                originalData = { ...data }; $('#sidebarTitle').text('Edit: ' + data.asset_no); $('#log-tab').removeClass('disabled');
                $('#data_id').val(data.id); $('#asset_no').val(data.asset_no); $('#status').val(data.status); $('#host_name').val(data.host_name); $('#owner').val(data.owner_name);

                if ($("#dept option[value='" + data.dept_name + "']").length > 0) {
                    $('#dept').val(data.dept_name);
                } else {
                    $('#dept').val('');
                }

                $('#detail').val(data.detail); $('#check_morn').prop('checked', data.check_morn); $('#check_night').prop('checked', data.check_night);
            }
            $('#sidebarBackdrop, #editorSidebar').addClass('active');
        }

        function checkDirtyAndClose() { if (isFormDirty && !confirm("Unsaved changes. Close?")) return; closeEditor(); }
        function closeEditor() { $('#sidebarBackdrop, #editorSidebar').removeClass('active'); isFormDirty = false; }
</script>
}