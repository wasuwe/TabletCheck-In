@using System.Web.Http
@using System.Web.Http.Controllers
@using System.Web.Http.Description
@using System.Collections.ObjectModel
@using Tablet_Check_In.Areas.HelpPage.Models
@model Collection<ApiDescription>

@{
    ViewBag.Title = "API Reference";
    ILookup<HttpControllerDescriptor, ApiDescription> apiGroups = Model.ToLookup(api => api.ActionDescriptor.ControllerDescriptor);
}

<link type="text/css" href="~/Areas/HelpPage/HelpPage.css" rel="stylesheet" />

<header class="help-page">
    <div class="content-wrapper d-flex align-items-center">
        <h1 class="mb-0"><i class="fa fa-terminal mr-2" style="opacity: 0.7;"></i> Tablet Check-IN <span style="color:#fff; font-weight:300;">@ViewBag.Title</span></h1>
    </div>
</header>

<div id="body" class="help-page">
    <section class="featured">
        <div class="content-wrapper">
            <h2 style="border:none; margin-top:0; font-size:1.8rem;">Developer Portal</h2>
            <p style="font-size:1.05rem; color:#aaa; max-width: 800px;">
                เอกสารนี้ใช้สำหรับอ้างอิง Web API ของระบบ <strong>Tablet Check-IN Center</strong><br />
                โครงสร้างของ API ถูกออกแบบมาให้รองรับการทำงานในรูปแบบ <span style="color:#00ff88;">RESTful HTTP Request</span> และตอบกลับข้อมูลด้วยโครงสร้าง <span style="color:#00ff88;">JSON</span>
            </p>
        </div>
    </section>

    <section class="content-wrapper main-content clear-fix">
        @foreach (var group in apiGroups)
        {
            @Html.DisplayFor(m => group, "ApiGroup")
        }
    </section>
</div>